generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus      @default(ACTIVE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  auditLogs    AuditLog[]
  payments     Payment[]
  scholarships Scholarship[]
  sessions     Session[]
  charges      StudentCharge[]
  student      Student?
  teacher      Teacher?
  roles        UserRole[]
  uploadedDocs StudentDocument[] @relation("UploadedBy")
  verifiedDocs StudentDocument[] @relation("VerifiedBy")
  createdFollowUps StudentFollowUp[] @relation("FollowUpCreator")
  resolvedFollowUps StudentFollowUp[] @relation("FollowUpResolver")

  // Bloqueo por intentos fallidos
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastFailedAttempt   DateTime?
  
  // 2FA TOTP
  totpSecret  String?   // Secreto para generar códigos (encriptado)
  totpEnabled Boolean   @default(false)
  totpVerified Boolean  @default(false) // Verificado tras setup inicial

  @@index([lastName, firstName])
  @@map("users")
}

model Role {
  id    String     @id @default(cuid())
  code  RoleCode   @unique
  name  String
  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Career {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  students   Student[]
  studyPlans StudyPlan[]

  @@map("careers")
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String?
  description String
  metadata    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Student {
  id                String                 @id @default(cuid())
  userId            String                 @unique
  dni               String                 @unique
  firstName         String
  lastName          String
  status            StudentStatus          @default(ACTIVE)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  careerId          String
  currentYear       Int                    @default(1)
  isBecado          Boolean                @default(false)
  isRecursante      Boolean                @default(false)
  attendanceEntries AttendanceEntry[]
  enrollments       Enrollment[]
  grades            Grade[]
  payments          Payment[]
  scholarships      Scholarship[]
  studentCharges    StudentCharge[]
  subjectStatuses   StudentSubjectStatus[]
  documents         StudentDocument[]
  followUps         StudentFollowUp[]
  career            Career                 @relation(fields: [careerId], references: [id])
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastName, firstName])
  @@map("students")
}

model Teacher {
  id          String              @id @default(cuid())
  userId      String              @unique
  dni         String              @unique
  firstName   String
  lastName    String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  commissions CommissionTeacher[]
  payslips    Payslip[]
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastName, firstName])
  @@map("teachers")
}

model Subject {
  id             String                 @id @default(cuid())
  code           String                 @unique
  name           String
  yearLevel      Int
  active         Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  commissions    Commission[]
  planLinks      PlanSubject[]
  statuses       StudentSubjectStatus[]
  requiredBy     SubjectCorrelative[]   @relation("subject_required")
  correlativesTo SubjectCorrelative[]   @relation("subject_main")

  @@index([name])
  @@map("subjects")
}

model AcademicTerm {
  id          String       @id @default(cuid())
  name        String
  year        Int
  startDate   DateTime
  endDate     DateTime
  active      Boolean      @default(true)
  commissions Commission[]

  @@unique([year, name])
  @@map("academic_terms")
}

model Commission {
  id             String              @id @default(cuid())
  subjectId      String
  termId         String
  name           String
  capacity       Int?
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  attendanceDays AttendanceRecord[]
  teachers       CommissionTeacher[]
  subject        Subject             @relation(fields: [subjectId], references: [id])
  term           AcademicTerm        @relation(fields: [termId], references: [id])
  enrollments    Enrollment[]
  grades         Grade[]

  @@unique([subjectId, termId, name])
  @@index([termId])
  @@map("commissions")
}

model CommissionTeacher {
  commissionId String
  teacherId    String
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  teacher      Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([commissionId, teacherId])
  @@map("commission_teachers")
}

model Enrollment {
  id           String           @id @default(cuid())
  studentId    String
  commissionId String
  status       EnrollmentStatus @default(PENDING)
  enrolledAt   DateTime         @default(now())
  commission   Commission       @relation(fields: [commissionId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, commissionId])
  @@index([commissionId, status])
  @@map("enrollments")
}

model SubjectCorrelative {
  subjectId         String
  requiredSubjectId String
  requiredSubject   Subject @relation("subject_required", fields: [requiredSubjectId], references: [id])
  subject           Subject @relation("subject_main", fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([subjectId, requiredSubjectId])
  @@map("subject_correlatives")
}

model AttendanceRecord {
  id              String            @id @default(cuid())
  commissionId    String
  classDate       DateTime
  createdByUserId String
  createdAt       DateTime          @default(now())
  entries         AttendanceEntry[]
  commission      Commission        @relation(fields: [commissionId], references: [id])

  @@unique([commissionId, classDate])
  @@map("attendance_records")
}

model AttendanceEntry {
  id           String           @id @default(cuid())
  attendanceId String
  studentId    String
  present      Boolean
  notes        String?
  attendance   AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id])

  @@unique([attendanceId, studentId])
  @@index([studentId])
  @@map("attendance_entries")
}

model Grade {
  id              String     @id @default(cuid())
  commissionId    String
  studentId       String
  value           Decimal    @db.Decimal(5, 2)
  gradeType       String
  gradedAt        DateTime   @default(now())
  createdByUserId String
  commission      Commission @relation(fields: [commissionId], references: [id])
  student         Student    @relation(fields: [studentId], references: [id])

  @@index([studentId, commissionId])
  @@map("grades")
}

model StudentSubjectStatus {
  id                String           @id @default(cuid())
  studentId         String
  subjectId         String
  attendancePercent Decimal          @default(0) @db.Decimal(5, 2)
  regularityStatus  RegularityStatus @default(LIBRE)
  approved          Boolean          @default(false)
  updatedAt         DateTime         @updatedAt
  student           Student          @relation(fields: [studentId], references: [id])
  subject           Subject          @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
  @@index([studentId, regularityStatus])
  @@map("student_subject_status")
}

model StudyPlan {
  id            String        @id @default(cuid())
  careerId      String
  name          String
  version       String
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  durationYears Int           @default(4)
  subjects      PlanSubject[]
  career        Career        @relation(fields: [careerId], references: [id])

  @@unique([careerId, version])
  @@map("study_plans")
}

model PlanSubject {
  planId    String
  subjectId String
  sortOrder Int
  plan      StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  subject   Subject   @relation(fields: [subjectId], references: [id])

  @@id([planId, subjectId])
  @@map("plan_subjects")
}

model ChargeConcept {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  description String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  charges     StudentCharge[]

  @@map("charge_concepts")
}

model StudentCharge {
  id          String              @id @default(cuid())
  studentId   String
  conceptId   String
  periodLabel String
  amount      Decimal             @db.Decimal(12, 2)
  paidAmount  Decimal             @default(0) @db.Decimal(12, 2)
  dueDate     DateTime?
  status      ChargeStatus        @default(PENDING)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  userId      String?
  allocations PaymentAllocation[]
  concept     ChargeConcept       @relation(fields: [conceptId], references: [id])
  student     Student             @relation(fields: [studentId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])

  @@index([studentId, status])
  @@index([periodLabel])
  @@map("student_charges")
}

model Payment {
  id          String              @id @default(cuid())
  studentId   String
  amount      Decimal             @db.Decimal(12, 2)
  method      PaymentMethod
  reference   String?
  paidAt      DateTime            @default(now())
  notes       String?
  createdAt   DateTime            @default(now())
  userId      String?
  allocations PaymentAllocation[]
  student     Student             @relation(fields: [studentId], references: [id])
  user        User?               @relation(fields: [userId], references: [id])

  @@index([studentId, paidAt])
  @@map("payments")
}

model PaymentAllocation {
  paymentId String
  chargeId  String
  amount    Decimal       @db.Decimal(12, 2)
  charge    StudentCharge @relation(fields: [chargeId], references: [id], onDelete: Cascade)
  payment   Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@id([paymentId, chargeId])
  @@map("payment_allocations")
}

model Scholarship {
  id         String    @id @default(cuid())
  studentId  String
  name       String
  percentage Decimal   @db.Decimal(5, 2)
  active     Boolean   @default(true)
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  userId     String?
  student    Student   @relation(fields: [studentId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])

  @@index([studentId, active])
  @@map("scholarships")
}

model Payslip {
  id          String        @id @default(cuid())
  teacherId   String
  periodMonth Int
  periodYear  Int
  amount      Decimal       @db.Decimal(12, 2)
  status      PayslipStatus @default(PENDING)
  fileUrl     String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  teacher     Teacher       @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, periodMonth, periodYear])
  @@index([teacherId, periodYear, periodMonth])
  @@map("payslips")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum RoleCode {
  SUPERADMIN
  DIRECTOR
  SECRETARIA
  DOCENTE
  ALUMNO
  FINANZAS
  APODERADO
  PRECEPTOR
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  DOWNLOAD
  BLOCKED_ATTEMPT
  EXPORT
}

// Permisos granulares por entidad (CRUD)
model Permission {
  id           String   @id @default(cuid())
  roleCode     RoleCode
  entity       String   // Ej: 'USER', 'STUDENT', 'CAREER', etc.
  canCreate    Boolean  @default(false)
  canRead      Boolean  @default(true)
  canUpdate    Boolean  @default(false)
  canDelete    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([roleCode, entity])
  @@index([roleCode])
  @@index([entity])
  @@map("permissions")
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  SUSPENDED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  REJECTED
  CANCELLED
}

enum RegularityStatus {
  REGULAR
  LIBRE
}

enum ChargeStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  DEBIT_CARD
  CREDIT_CARD
  QR
  SCHOLARSHIP
}

enum PayslipStatus {
  PENDING
  PAID
  CANCELLED
}

enum DocumentType {
  DNI
  CERTIFICATE
  CONSTANCY
  SECONDARY_TITLE
  PHOTO_ID
  MEDICAL_CERTIFICATE
  OTHER
}

model StudentDocument {
  id          String       @id @default(cuid())
  studentId   String
  type        DocumentType
  name        String
  fileUrl     String
  fileSize    Int?         // Tamaño en bytes
  mimeType    String?      // Tipo MIME
  uploadedBy  String
  verified    Boolean      @default(false)
  verifiedBy  String?
  verifiedAt  DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  uploader    User         @relation("UploadedBy", fields: [uploadedBy], references: [id])
  verifier    User?        @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@index([studentId, type])
  @@map("student_documents")
}

enum FollowUpType {
  INTERVIEW
  OBSERVATION
  WARNING
  MEETING
  INCIDENT
  ACHIEVEMENT
  NOTE
}

model StudentFollowUp {
  id          String       @id @default(cuid())
  studentId   String
  type        FollowUpType
  title       String
  description String
  date        DateTime     @default(now())
  createdBy   String
  isAlert     Boolean      @default(false)  // Destacar como alerta/importante
  isResolved  Boolean      @default(false)   // Para alertas: ya fue resuelta
  resolvedAt  DateTime?
  resolvedBy  String?
  attachments String?      // URLs de archivos adjuntos separados por coma
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  creator     User         @relation("FollowUpCreator", fields: [createdBy], references: [id])
  resolver    User?        @relation("FollowUpResolver", fields: [resolvedBy], references: [id])

  @@index([studentId, date])
  @@index([studentId, type])
  @@map("student_followups")
}
